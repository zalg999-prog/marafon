<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Кухонный марафон</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: #0A0C10;
            color: #EDF2F7;
            line-height: 1.5;
        }
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 1.5rem;
        }
        .header {
            text-align: center;
            padding: 2rem 0 1rem;
            border-bottom: 1px solid rgba(255, 107, 43, 0.3);
            margin-bottom: 2rem;
        }
        .badge {
            display: inline-block;
            background: linear-gradient(135deg, #FF6B2B, #FF3B00);
            padding: 0.3rem 1rem;
            border-radius: 40px;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 1px;
            margin-bottom: 1rem;
        }
        h1 {
            font-size: 2.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #FFFFFF, #FFB347);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0.5rem;
        }
        .subhead {
            font-size: 1.2rem;
            color: #A0AEC0;
            margin-bottom: 1.5rem;
        }
        .timer-section {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem;
            justify-content: center;
            margin-bottom: 3rem;
        }
        .timer-card {
            background: #11161D;
            border-radius: 28px;
            padding: 1.2rem 1.8rem;
            flex: 1;
            min-width: 220px;
            text-align: center;
            border: 1px solid #2D3748;
        }
        .timer-card h3 {
            font-size: 1.1rem;
            font-weight: 600;
            color: #FFB347;
            margin-bottom: 0.8rem;
        }
        .timer-clock {
            font-size: 2rem;
            font-weight: 800;
            font-family: monospace;
            background: #00000055;
            padding: 0.5rem;
            border-radius: 20px;
        }
        .conditions {
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            margin-bottom: 3rem;
        }
        .card {
            flex: 1;
            background: #11161D;
            border-radius: 32px;
            padding: 2rem;
            border: 1px solid #2D3748;
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-4px);
            border-color: #FF6B2B;
        }
        .card-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        .card-title {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }
        .prize {
            font-size: 2rem;
            font-weight: 800;
            color: #FFB347;
            margin: 0.75rem 0;
        }
        .list {
            list-style: none;
            margin: 1rem 0;
        }
        .list li {
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .rules {
            background: #0F141A;
            border-radius: 28px;
            padding: 1.8rem;
            margin-bottom: 2.5rem;
            border-left: 5px solid #FF6B2B;
        }
        .form-block {
            background: #11161D;
            border-radius: 32px;
            padding: 1.5rem;
            margin-bottom: 2.5rem;
            border: 1px solid #2D3748;
            text-align: center;
        }
        .form-block h2 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
        }
        .form-wrapper {
            border-radius: 24px;
            overflow: hidden;
            margin-top: 1rem;
        }
        .motivation {
            background: linear-gradient(120deg, #1E2A3A, #0F141A);
            border-radius: 32px;
            padding: 2rem;
            text-align: center;
            margin: 2rem 0;
        }
        .footer {
            text-align: center;
            padding: 2rem 0 1rem;
            color: #5A6E8A;
            font-size: 0.8rem;
            border-top: 1px solid #1E2A3A;
            margin-top: 2rem;
        }
        @media (max-width: 750px) {
            h1 { font-size: 2rem; }
            .card-title { font-size: 1.4rem; }
            .prize { font-size: 1.6rem; }
            .timer-clock { font-size: 1.4rem; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="badge">🔥 КУХОННЫЙ МАРАФОН 🔥</div>
        <h1>ДВЕ ЦЕЛИ — ДВА ПРИЗА</h1>
        <div class="subhead">Кто быстрее, смелее и голоднее до побед?</div>
    </div>

    <div class="timer-section">
        <div class="timer-card">
            <h3>🏁 ДО КОНЦА «НЕДЕЛЬНОГО УРАГАНА»</h3>
            <div class="timer-clock" id="weekTimer">-- дн -- ч -- мин -- сек</div>
        </div>
        <div class="timer-card">
            <h3>⚡ ДО КОНЦА «ВЫХОДНОГО СПРИНТА»</h3>
            <div class="timer-clock" id="weekendTimer">-- дн -- ч -- мин -- сек</div>
        </div>
    </div>

    <div class="conditions">
        <div class="card">
            <div class="card-icon">🥇</div>
            <div class="card-title">НЕДЕЛЬНЫЙ УРАГАН</div>
            <div class="prize">20 000 ₽</div>
            <p>📅 За календарную неделю (пн–вс) продаёшь <strong>7 кухонь</strong> → сертификат:</p>
            <ul class="list">
                <li>🛒 Ozon / Wildberries</li>
                <li>🍣 Ресторанный альянс (ужин для двоих)</li>
                <li>🎮 М.Видео или DNS</li>
            </ul>
        </div>
        <div class="card">
            <div class="card-icon">⚡</div>
            <div class="card-title">ВЫХОДНОЙ СПРИНТ</div>
            <div class="prize">10 000 ₽</div>
            <p>🗓️ За субботу + воскресенье продаёшь <strong>3 кухни</strong> → сертификат:</p>
            <ul class="list">
                <li>💆 СПА-день (массаж, хамам)</li>
                <li>🎫 Яндекс Афиша / Кассир.ру (концерт, стендап для двоих)</li>
                <li>🛍️ Lamoda или Goldapple (парфюм / дизайн)</li>
            </ul>
        </div>
    </div>

    <div class="rules">
        <h3>🎯 Правила простые</h3>
        <p>✔️ Отсчёт – с момента старта конкурса (понедельник, 00:00).</p>
        <p>✔️ Зачёт по факту <strong>подписанных договоров</strong>.</p>
        <p>✔️ Можно выиграть <strong>оба приза</strong> – забрать 30 000 ₽.</p>
        <p>🚀 <strong>Будь экспертом в своем деле!</strong></p>
    </div>

    <div class="form-block">
        <h2>📝 ДОБАВИТЬ ПРОДАЖУ</h2>
        <p>Выбери себя, укажи количество кухонь — и данные попадут в общую таблицу.</p>
        <div class="form-wrapper">
            <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSdMGaF-SaaTWEDogV3RTyfDuTh8ZRa_WmOxBljgqaebvO4DrA/viewform?embedded=true" width="100%" height="650" frameborder="0" marginheight="0" marginwidth="0" style="border-radius: 20px;">Загрузка…</iframe>
        </div>
        <p style="margin-top: 1rem; font-size: 0.85rem; color: #A0AEC0;">📌 Все ответы автоматически сохраняются. Таблицу с итогами смотрит организатор.</p>
    </div>

    <div class="motivation">
        <p style="font-size: 1.3rem; font-weight: 700;">💪 Ты уже продаёшь кухни? Значит, можешь продать больше!</p>
        <p>⏰ 7 кухонь за неделю — это всего одна кухня в день.<br>
        ⚡ «Выходной спринт» — 48 часов, чтобы взять 3 подписи. Одна в субботу, две в воскресенье — и 10 000 ₽ твои.</p>
        <p style="margin-top: 1rem; font-weight: 800;">🏆 Двойной удар: выполнишь оба условия – заберёшь 30 000 ₽!</p>
    </div>

    <div class="footer">
        © Кухонный марафон | Старт: понедельник, финиш: воскресенье 23:59
    </div>
</div>

<script>
    function getNextSunday() {
        let now = new Date();
        let day = now.getDay();
        let daysUntilSunday = (day === 0 ? 0 : 7 - day);
        let nextSunday = new Date(now);
        nextSunday.setDate(now.getDate() + daysUntilSunday);
        nextSunday.setHours(23, 59, 59, 999);
        return nextSunday;
    }
    function getWeekendEnd() {
        let now = new Date();
        let currentDay = now.getDay();
        let targetSunday = new Date(now);
        if (currentDay === 6) targetSunday.setDate(now.getDate() + 1);
        else if (currentDay === 0) targetSunday = now;
        else targetSunday.setDate(now.getDate() + (7 - currentDay));
        targetSunday.setHours(23, 59, 59, 999);
        return targetSunday;
    }
    function updateTimers() {
        const now = new Date();
        const weekEnd = getNextSunday();
        const weekendEnd = getWeekendEnd();
        function getDiff(endDate) {
            let diff = endDate - now;
            if (diff <= 0) return "Завершён";
            let days = Math.floor(diff / (1000*60*60*24));
            let hours = Math.floor((diff % 86400000) / 3600000);
            let minutes = Math.floor((diff % 3600000) / 60000);
            let seconds = Math.floor((diff % 60000) / 1000);
            return `${days}д ${hours}ч ${minutes}м ${seconds}с`;
        }
        document.getElementById('weekTimer').innerText = getDiff(weekEnd);
        document.getElementById('weekendTimer').innerText = getDiff(weekendEnd);
    }
    updateTimers();
    setInterval(updateTimers, 1000);
</script>
</body>
</html>
